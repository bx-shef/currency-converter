# Скопировать в .env.prod на сервере рядом с docker-compose.prod.yml
# НЕ коммитить .env.prod в git!

# Домен сайта (DNS должен указывать на IP сервера)
DOMAIN=currency.example.com

# Email для SSL-сертификата Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Яндекс.Метрика — задаётся в GitHub Secrets, не здесь
# (запекается в Docker-образ при сборке CI)
# NUXT_PUBLIC_YANDEX_COUNTER_ID=
