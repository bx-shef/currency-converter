# Яндекс.Метрика — ID счётчика (только цифры, получить на metrika.yandex.ru)
NUXT_PUBLIC_YANDEX_COUNTER_ID=

# Публичный URL сайта — нужен для корректного og:image URL (https://your-domain.com)
NUXT_SITE_URL=

# Разрешённые хосты для dev-сервера (через запятую)
# Нужно при использовании туннелей (ngrok, localtunnel и т.д.)
NUXT_ALLOWED_HOSTS=
